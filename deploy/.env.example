# Copy this to deploy/.env and fill in your values
# Never commit deploy/.env

# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production-minimum-32-chars

# Database
POSTGRES_USER=eventgame
POSTGRES_PASSWORD=changeme
POSTGRES_DB=event_game_dev
DATABASE_URL=postgresql+psycopg://eventgame:changeme@postgres:5432/event_game_dev

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change-me-minimum-32-chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost

# AI Provider (choose one or configure multiple)
AI_PROVIDER=ollama               # ollama | claude | openai
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Azure OAuth (optional)
AZURE_OAUTH_ENABLED=false
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# Frontend
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws
